# ── MercadoPago ───────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-xxxxx...          # Access Token de producción (servidor)
MP_PUBLIC_KEY=APP_USR-xxxxx...            # Public Key (frontend)
MP_WEBHOOK_SECRET=xxxxx                   # Secreto de firma para webhooks (Panel MP → Webhooks)

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...     # Service Role Key (nunca en frontend)
SUPABASE_ANON_KEY=eyJhbGci...            # Anon Key (puede ir en frontend)

# ── hCaptcha ──────────────────────────────────────────────────────────────────
HCAPTCHA_SECRET=xxxxx                     # Secret Key (servidor)
HCAPTCHA_SITE_KEY=xxxxx                   # Site Key (frontend / pagar.html)

# ── URLs ──────────────────────────────────────────────────────────────────────
LANDING_URL=https://tu-dominio.com        # URL de la landing (sin trailing slash)
BACKEND_URL=https://api.tu-dominio.com    # URL pública de este servidor (para webhooks)
CORS_ORIGIN=https://tu-dominio.com        # Origen permitido para CORS (o * en desarrollo)

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
